<Window x:Class="LicenseManager.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:System="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="授权码生成管理系统" Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="200"/>
        </Grid.RowDefinitions>
        
        <Border Grid.Row="0" Background="#FF2D2D30" Padding="15,10">
            <TextBlock Text="授权码生成管理系统" 
                       Foreground="White" FontSize="18" FontWeight="Bold"/>
        </Border>
        
        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <Border Grid.Column="0" BorderBrush="#FFCCCCCC" BorderThickness="1" Margin="0,0,10,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <TextBlock Text="添加授权记录" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                        
                        <StackPanel Margin="0,5">
                            <TextBlock Text="记录时间:" VerticalAlignment="Center"/>
                            <DatePicker x:Name="RecordDatePicker" SelectedDate="{x:Static System:DateTime.Now}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock Text="时间:" VerticalAlignment="Center" Width="40"/>
                                <TextBox x:Name="RecordTimeText" Text="" Width="100"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <StackPanel Margin="0,5">
                            <TextBlock Text="部门:" VerticalAlignment="Center"/>
                            <ComboBox x:Name="DepartmentCombo" SelectedIndex="0">
                                <ComboBoxItem>软件</ComboBoxItem>
                                <ComboBoxItem>售前</ComboBoxItem>
                            </ComboBox>
                        </StackPanel>
                        
                        <StackPanel Margin="0,5">
                            <TextBlock Text="记录人:" VerticalAlignment="Center"/>
                            <ComboBox x:Name="OperatorCombo" SelectedIndex="0">
                                <ComboBoxItem>彭耀东</ComboBoxItem>
                                <ComboBoxItem>欧阳键峰</ComboBoxItem>
                                <ComboBoxItem>李珂</ComboBoxItem>
                            </ComboBox>
                        </StackPanel>
                        
                        <StackPanel Margin="0,5">
                            <TextBlock Text="设备类型:" VerticalAlignment="Center"/>
                            <ComboBox x:Name="DeviceTypeCombo" SelectedIndex="0" SelectionChanged="DeviceTypeCombo_SelectionChanged">
                                <ComboBoxItem>高速贴片机</ComboBoxItem>
                                <ComboBoxItem>猎奇耦合测试机</ComboBoxItem>
                                <ComboBoxItem>飞泰耦合测试机</ComboBoxItem>
                                <ComboBoxItem>芯片测试机</ComboBoxItem>
                            </ComboBox>
                        </StackPanel>
                        
                        <StackPanel Margin="0,5">
                            <TextBlock Text="项目号:" VerticalAlignment="Center"/>
                            <TextBox x:Name="ProjectNumberText" Text=""/>
                        </StackPanel>
                        
                        <StackPanel Margin="0,5">
                            <TextBlock Text="设备号:" VerticalAlignment="Center"/>
                            <TextBox x:Name="DeviceNumberText" Text=""/>
                        </StackPanel>
                        
                        <StackPanel Margin="0,5">
                            <TextBlock Text="机器码文件:" VerticalAlignment="Center"/>
                            <TextBox x:Name="MachineCodeText" Text="" AllowDrop="True" Background="#FFF0F0F0" Height="80" TextWrapping="Wrap" PreviewDragOver="TextBox_PreviewDragOver" Drop="MachineCodeText_Drop"/>
                            <TextBlock Text="(支持拖放文件或粘贴文本)" FontSize="10" Foreground="Gray" Margin="0,1,0,0"/>
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <Button x:Name="ImportMachineCodeBtn" Content="导入..." Width="60" Margin="0,0,5,0" Click="ImportMachineCodeBtn_Click"/>
                                <Button x:Name="ViewMachineCodeBtn" Content="查看" Width="50" Click="ViewMachineCodeBtn_Click"/>
                                <Button x:Name="ClearMachineCodeBtn" Content="清空" Width="50" Margin="0,0,5,0" Click="ClearMachineCodeBtn_Click"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <StackPanel Margin="0,5">
                            <TextBlock Text="授权工具:" VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <Button x:Name="OpenLicenseToolBtn" Content="打开授权软件" Width="100" Click="OpenLicenseToolBtn_Click"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                            <Button x:Name="SaveBtn" Content="保存记录" Width="90" Margin="5,0" Click="SaveBtn_Click" Background="#FF4CAF50" Foreground="White"/>
                            <Button x:Name="ClearBtn" Content="清空表单" Width="90" Margin="5,0" Click="ClearBtn_Click"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
            
            <Border Grid.Column="1" BorderBrush="#FFCCCCCC" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="授权记录列表" FontWeight="Bold" FontSize="14" 
                               Margin="10,5" HorizontalAlignment="Center"/>
                    
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="10,5">
                        <TextBlock Text="搜索:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBox x:Name="SearchText" Width="150" Margin="0,0,5,0" ToolTip="项目号/设备号"/>
                        <ComboBox x:Name="SearchDeviceTypeCombo" Width="120" Margin="0,0,5,0" SelectedIndex="0">
                            <ComboBoxItem>全部设备</ComboBoxItem>
                            <ComboBoxItem>高速贴片机</ComboBoxItem>
                            <ComboBoxItem>猎奇耦合测试机</ComboBoxItem>
                            <ComboBoxItem>飞泰耦合测试机</ComboBoxItem>
                            <ComboBoxItem>芯片测试机</ComboBoxItem>
                        </ComboBox>
                        <Button x:Name="SearchBtn" Content="搜索" Width="60" Margin="0,0,5,0" Click="SearchBtn_Click"/>
                        <Button x:Name="RefreshBtn" Content="刷新" Width="60" Click="RefreshBtn_Click"/>
                    </StackPanel>
                    
                    <DataGrid Grid.Row="2" x:Name="LicenseRecordGrid" AutoGenerateColumns="False" 
                              IsReadOnly="True" Margin="5" CanUserAddRows="False"
                              SelectionMode="Single" SelectionChanged="LicenseRecordGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                            <DataGridTextColumn Header="记录时间" Binding="{Binding RecordTime, StringFormat=yyyy-MM-dd HH:mm}" Width="120"/>
                            <DataGridTextColumn Header="部门" Binding="{Binding Department}" Width="80"/>
                            <DataGridTextColumn Header="记录人" Binding="{Binding Operator}" Width="80"/>
                            <DataGridTextColumn Header="项目号" Binding="{Binding ProjectNumber}" Width="100"/>
                            <DataGridTextColumn Header="设备号" Binding="{Binding DeviceNumber}" Width="100"/>
                            <DataGridTextColumn Header="机器码" Binding="{Binding MachineCodeShort}" Width="80"/>
                            <DataGridTemplateColumn Header="操作" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="导出" Width="50" Margin="2" Click="ExportRecordBtn_Click" Tag="{Binding Id}"/>
                                            <Button Content="删除" Width="50" Margin="2" Click="DeleteRecordBtn_Click" Tag="{Binding Id}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
        
        <Border Grid.Row="2" BorderBrush="#FFCCCCCC" BorderThickness="1" Margin="10,0,10,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" Background="#FFF0F0F0" Margin="5">
                    <TextBlock Text="操作日志" FontWeight="Bold" VerticalAlignment="Center"/>
                    <Button x:Name="ClearLogBtn" Content="清空" Width="60" Margin="10,0,0,0" Click="ClearLogBtn_Click"/>
                    <Button x:Name="ExportLogBtn" Content="导出日志" Width="70" Margin="10,0,0,0" Click="ExportLogBtn_Click"/>
                </StackPanel>
                <TextBox Grid.Row="1" x:Name="LogTextBox" IsReadOnly="True" 
                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas" FontSize="12" TextWrapping="Wrap"/>
            </Grid>
        </Border>
    </Grid>
</Window>
