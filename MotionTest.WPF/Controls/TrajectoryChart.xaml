<UserControl x:Class="MotionTest.WPF.Controls.TrajectoryChart"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="400" d:DesignWidth="800"
             Background="White">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 工具栏 -->
        <ToolBar Grid.Row="0" Background="#F0F0F0">
            <ComboBox x:Name="cmbDisplayMode" Width="120" Margin="5,2" 
                      SelectedIndex="0" SelectionChanged="cmbDisplayMode_SelectionChanged">
                <ComboBoxItem Content="位置-时间"/>
                <ComboBoxItem Content="速度-时间"/>
                <ComboBoxItem Content="位置-位置(X-Y)"/>
                <ComboBoxItem Content="综合显示"/>
            </ComboBox>
            <Separator/>
            <CheckBox x:Name="chkShowAxis0" Content="轴0" IsChecked="True" Margin="5,2" 
                      Checked="AxisVisibilityChanged" Unchecked="AxisVisibilityChanged"/>
            <CheckBox x:Name="chkShowAxis1" Content="轴1" IsChecked="True" Margin="5,2" 
                      Checked="AxisVisibilityChanged" Unchecked="AxisVisibilityChanged"/>
            <CheckBox x:Name="chkShowAxis2" Content="轴2" IsChecked="False" Margin="5,2" 
                      Checked="AxisVisibilityChanged" Unchecked="AxisVisibilityChanged"/>
            <CheckBox x:Name="chkShowAxis3" Content="轴3" IsChecked="False" Margin="5,2" 
                      Checked="AxisVisibilityChanged" Unchecked="AxisVisibilityChanged"/>
            <Separator/>
            <Button x:Name="btnZoomIn" Content="放大" Margin="2" Padding="8,2" Click="btnZoomIn_Click"/>
            <Button x:Name="btnZoomOut" Content="缩小" Margin="2" Padding="8,2" Click="btnZoomOut_Click"/>
            <Button x:Name="btnResetZoom" Content="重置" Margin="2" Padding="8,2" Click="btnResetZoom_Click"/>
            <Separator/>
            <Button x:Name="btnExport" Content="导出CSV" Margin="2" Padding="8,2" Click="btnExport_Click"/>
        </ToolBar>
        
        <!-- 图表区域 -->
        <Border Grid.Row="1" BorderBrush="#CCCCCC" BorderThickness="1" Margin="5">
            <Grid>
                <Canvas x:Name="chartCanvas" Background="#FAFAFA" 
                        ClipToBounds="True"
                        MouseWheel="chartCanvas_MouseWheel"
                        MouseLeftButtonDown="chartCanvas_MouseLeftButtonDown"
                        MouseLeftButtonUp="chartCanvas_MouseLeftButtonUp"
                        MouseMove="chartCanvas_MouseMove"/>
                
                <!-- 图例 -->
                <StackPanel x:Name="legendPanel" HorizontalAlignment="Right" VerticalAlignment="Top" 
                           Margin="10" Background="#80FFFFFF" Orientation="Vertical">
                </StackPanel>
                
                <!-- 测量信息 -->
                <Border x:Name="measurementPanel" HorizontalAlignment="Left" VerticalAlignment="Top" 
                       Margin="10" Background="#E0FFFFFF" BorderBrush="#AAAAAA" BorderThickness="1"
                       Padding="8,5" Visibility="Collapsed">
                    <TextBlock x:Name="txtMeasurement" FontSize="11" FontFamily="Consolas"/>
                </Border>
            </Grid>
        </Border>
        
        <!-- 状态栏 -->
        <StatusBar Grid.Row="2" Background="#F0F0F0">
            <TextBlock x:Name="txtStatus" Text="就绪" Margin="5,2"/>
            <Separator/>
            <TextBlock x:Name="txtDataInfo" Text="" Margin="5,2"/>
            <TextBlock x:Name="txtCursorInfo" Text="" Margin="5,2"/>
        </StatusBar>
    </Grid>
</UserControl>
