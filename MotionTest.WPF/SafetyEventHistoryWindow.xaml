<Window x:Class="MotionTest.WPF.SafetyEventHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:MotionTest.WPF.ViewModels"
        mc:Ignorable="d"
        Title="安全事件历史查询" Height="650" Width="1000"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Border Grid.Row="0" Background="#FF2D2D30" Padding="15,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="📋 安全事件历史查询" 
                           Foreground="White" FontSize="18" FontWeight="Bold"/>
                <TextBlock Grid.Column="1" Text="{Binding ResultCount, StringFormat=共 {0} 条记录}" 
                           Foreground="White" VerticalAlignment="Center" Margin="10,0"/>
            </Grid>
        </Border>

        <!-- 筛选栏 -->
        <Border Grid.Row="1" Background="#FFF5F5F5" BorderBrush="#FFCCCCCC" BorderThickness="0,0,0,1" Padding="10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="开始:" VerticalAlignment="Center" Margin="0,0,3,0"/>
                <DatePicker SelectedDate="{Binding StartDate}" VerticalAlignment="Center" Width="120"/>
                <TextBlock Text="结束:" VerticalAlignment="Center" Margin="10,0,3,0"/>
                <DatePicker SelectedDate="{Binding EndDate}" VerticalAlignment="Center" Width="120"/>
                
                <Separator Margin="10,0" Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"/>
                
                <TextBlock Text="级别:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <CheckBox Content="Info" IsChecked="{Binding IncludeInfo}" VerticalAlignment="Center" Margin="3,0"/>
                <CheckBox Content="Warning" IsChecked="{Binding IncludeWarning}" VerticalAlignment="Center" Margin="3,0"/>
                <CheckBox Content="Error" IsChecked="{Binding IncludeError}" VerticalAlignment="Center" Margin="3,0"/>
                <CheckBox Content="Fatal" IsChecked="{Binding IncludeFatal}" VerticalAlignment="Center" Margin="3,0"/>
                
                <Separator Margin="10,0" Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"/>
                
                <TextBlock Text="关键词:" VerticalAlignment="Center" Margin="0,0,3,0"/>
                <TextBox Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}" 
                         VerticalAlignment="Center" Width="150" Margin="0,0,5,0"/>
                
                <Button Content="🔍 查询" Width="70" Margin="3,0" 
                        Command="{Binding SearchCommand}" Background="#FF2196F3" Foreground="White"/>
                <Button Content="🔄 刷新" Width="70" Margin="3,0" 
                        Command="{Binding RefreshCommand}"/>
                <Button Content="❌ 清除" Width="70" Margin="3,0" 
                        Command="{Binding ClearFiltersCommand}"/>
                <Button Content="📤 导出" Width="70" Margin="10,0,3,0" 
                        Command="{Binding ExportCommand}" Background="#FF4CAF50" Foreground="White"/>
            </StackPanel>
        </Border>

        <!-- 数据表格 -->
        <Border Grid.Row="2" BorderBrush="#FFCCCCCC" BorderThickness="1" Margin="5">
            <DataGrid ItemsSource="{Binding Logs}" AutoGenerateColumns="False" 
                      IsReadOnly="True" Margin="2" CanUserAddRows="False"
                      CanUserSortColumns="True" SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Padding" Value="0,0,5,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="时间" Binding="{Binding TimeText}" Width="160"/>
                    <DataGridTextColumn Header="级别" Binding="{Binding Level}" Width="70">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{Binding LevelBrush}"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Logger" Binding="{Binding LoggerName}" Width="120"/>
                    <DataGridTextColumn Header="消息" Binding="{Binding Message}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextWrapping" Value="Wrap"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="附加信息" Binding="{Binding AdditionalInfo}" Width="150">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="Gray"/>
                                <Setter Property="FontSize" Value="11"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- 底部状态栏 -->
        <Border Grid.Row="3" Background="#FFF0F0F0" Padding="10,5">
            <TextBlock>
                <Run Text="提示: 支持按时间范围、级别、关键词筛选。最多显示 500 条记录。"/>
                <Run Text="  当前结果: " FontWeight="Bold"/>
                <Run Text="{Binding ResultCount}" FontWeight="Bold"/>
                <Run Text=" 条" FontWeight="Bold"/>
            </TextBlock>
        </Border>
    </Grid>
</Window>
