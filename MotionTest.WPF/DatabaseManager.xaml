<Window x:Class="MotionTest.WPF.DatabaseManager"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="数据库管理"
        Width="800"
        Height="600"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <!-- 标签页 -->
        <TabControl Grid.Row="0" x:Name="tabControl" BorderBrush="#FF808080" BorderThickness="0,0,0,1">
            <TabItem Header="轴参数">
                <Grid />
            </TabItem>
            <TabItem Header="IO参数">
                <Grid />
            </TabItem>
        </TabControl>

        <!-- 内容区域 -->
        <Grid Grid.Row="1">
            <!-- 轴参数内容 -->
            <Grid x:Name="gridAxis" Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="40" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="200" />
                </Grid.RowDefinitions>

                <!-- 轴选择 -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10">
                    <Label Content="选择轴:" VerticalAlignment="Center" />
                    <ComboBox x:Name="cmbAxis" Width="200" Margin="5,0,0,0" SelectionChanged="cmbAxis_SelectionChanged" />
                    <Button x:Name="btnAddAxis" Content="添加轴" Margin="10,0,0,0" Click="btnAddAxis_Click" />
                    <Button x:Name="btnDeleteAxis" Content="删除轴" Margin="5,0,0,0" Click="btnDeleteAxis_Click" />
                </StackPanel>

                <!-- 轴参数列表 -->
                <DataGrid Grid.Row="1" x:Name="dgAxisParams" AutoGenerateColumns="False" Margin="10">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="参数" Binding="{Binding Path}" IsReadOnly="True" Width="150" />
                        <DataGridTextColumn Header="值" Binding="{Binding Value}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>

                <!-- 轴参数详细编辑 -->
                <Border Grid.Row="2" Margin="10" BorderBrush="#FF808080" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <Label Content="详细参数编辑:" FontWeight="Bold" />
                            <Button x:Name="btnSaveAxis" Content="保存" Margin="10,0,0,0" Click="btnSaveAxis_Click" />
                        </StackPanel>

                        <ScrollViewer Grid.Row="1">
                            <StackPanel x:Name="stackAxisParams" />
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- IO参数内容 -->
            <Grid x:Name="gridIO" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="40" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="200" />
                </Grid.RowDefinitions>

                <!-- IO选择 -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10">
                    <Label Content="选择IO:" VerticalAlignment="Center" />
                    <ComboBox x:Name="cmbIO" Width="200" Margin="5,0,0,0" SelectionChanged="cmbIO_SelectionChanged" />
                    <Button x:Name="btnAddIO" Content="添加IO" Margin="10,0,0,0" Click="btnAddIO_Click" />
                    <Button x:Name="btnDeleteIO" Content="删除IO" Margin="5,0,0,0" Click="btnDeleteIO_Click" />
                </StackPanel>

                <!-- IO参数列表 -->
                <DataGrid Grid.Row="1" x:Name="dgIOParams" AutoGenerateColumns="False" Margin="10">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="参数" Binding="{Binding Path}" IsReadOnly="True" Width="150" />
                        <DataGridTextColumn Header="值" Binding="{Binding Value}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>

                <!-- IO参数详细编辑 -->
                <Border Grid.Row="2" Margin="10" BorderBrush="#FF808080" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <Label Content="详细参数编辑:" FontWeight="Bold" />
                            <Button x:Name="btnSaveIO" Content="保存" Margin="10,0,0,0" Click="btnSaveIO_Click" />
                        </StackPanel>

                        <ScrollViewer Grid.Row="1">
                            <StackPanel x:Name="stackIOParams" />
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- 状态栏 -->
        <StatusBar Grid.Row="2" Background="#F0F0F0">
            <StatusBarItem>
                <TextBlock x:Name="txtStatus" Text="就绪" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
