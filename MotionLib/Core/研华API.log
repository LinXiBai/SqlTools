    public static uint mAcm_DevUpLoadMapInfo(IntPtr DeviceHandle, ushort MapType, DEV_IO_MAP_INFO[] MapInfoArray, ref uint ArrayLength)
    {
        uint result = 0u;
        if (MapInfoArray == null || MapInfoArray.Length < 1)
        {
            return result;
        }

        int cb = Marshal.SizeOf(typeof(DEV_IO_MAP_INFO)) * MapInfoArray.Length;
        IntPtr intPtr = Marshal.AllocHGlobal(cb);
        result = Acm_DevUpLoadMapInfo(DeviceHandle, MapType, intPtr, ref ArrayLength);
        if (result != 0)
        {
            return result;
        }

        for (int i = 0; i < MapInfoArray.Length; i++)
        {
            IntPtr ptr = new IntPtr(intPtr.ToInt64() + Marshal.SizeOf(typeof(DEV_IO_MAP_INFO)) * i);
            ref DEV_IO_MAP_INFO reference = ref MapInfoArray[i];
            reference = (DEV_IO_MAP_INFO)Marshal.PtrToStructure(ptr, typeof(DEV_IO_MAP_INFO));
        }

        Marshal.FreeHGlobal(intPtr);
        return result;
    }

    [DllImport("ADVMOT.dll", CallingConvention = CallingConvention.StdCall)]
    private static extern uint Acm_DevUpLoadMapInfo(IntPtr DeviceHandle, ushort MapType, IntPtr pMapInfoArray, ref uint ArrayLength);

