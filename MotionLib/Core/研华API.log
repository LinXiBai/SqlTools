    public static uint mAcm_GmGetToolLengthOffset(IntPtr GMSHandle, HToToolLengthOffset[] pToolLengthOffset, ref uint pTLOArrayLength)
    {
        uint result = 0u;
        if (pToolLengthOffset == null || pToolLengthOffset.Length < 1)
        {
            return result;
        }

        int cb = Marshal.SizeOf(typeof(HToToolLengthOffset)) * pToolLengthOffset.Length;
        IntPtr intPtr = Marshal.AllocHGlobal(cb);
        result = Acm_GmGetToolLengthOffset(GMSHandle, intPtr, ref pTLOArrayLength);
        if (result != 0)
        {
            return result;
        }

        for (int i = 0; i < pToolLengthOffset.Length; i++)
        {
            IntPtr ptr = new IntPtr(intPtr.ToInt64() + Marshal.SizeOf(typeof(HToToolLengthOffset)) * i);
            ref HToToolLengthOffset reference = ref pToolLengthOffset[i];
            reference = (HToToolLengthOffset)Marshal.PtrToStructure(ptr, typeof(HToToolLengthOffset));
        }

        Marshal.FreeHGlobal(intPtr);
        return result;
    }

