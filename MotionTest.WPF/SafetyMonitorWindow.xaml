<Window x:Class="MotionTest.WPF.SafetyMonitorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:MotionTest.WPF.ViewModels"
        mc:Ignorable="d"
        Title="安全防护监控中心 (MVVM)" Height="750" Width="1100"
        WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <vm:SafetyMonitorViewModel/>
    </Window.DataContext>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="200"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Border Grid.Row="0" Background="#FF2D2D30" Padding="15,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="🔒 安全防护监控中心 (MVVM)" 
                           Foreground="White" FontSize="18" FontWeight="Bold"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="总体状态:" Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <Ellipse Width="16" Height="16" 
                             Fill="{Binding OverallStatusBrush}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBlock Text="{Binding OverallStatusText}" 
                               Foreground="{Binding OverallStatusBrush}" FontWeight="Bold" 
                               VerticalAlignment="Center" Width="80"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 控制栏 -->
        <Border Grid.Row="1" Background="#FFF5F5F5" BorderBrush="#FFCCCCCC" BorderThickness="0,0,0,1" Padding="10">
            <StackPanel Orientation="Horizontal">
                <Button Content="初始化安全系统" Width="120" Margin="5,0"
                        Command="{Binding InitializeSafetyCommand}" 
                        Background="#FF2196F3" Foreground="White"/>
                <Button Content="启动监控" Width="100" Margin="5,0"
                        Command="{Binding StartMonitorCommand}" 
                        Background="#FF4CAF50" Foreground="White"/>
                <Button Content="停止监控" Width="100" Margin="5,0"
                        Command="{Binding StopMonitorCommand}" 
                        Background="#FFFF9800" Foreground="White"/>
                <Button Content="🛑 急停" Width="100" Margin="5,0"
                        Command="{Binding EmergencyStopCommand}" 
                        Background="#FFF44336" Foreground="White" FontWeight="Bold"/>
                <Separator Margin="10,0" Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"/>
                <Button Content="+ 添加体积" Width="90" Margin="5,0"
                        Command="{Binding AddVolumeCommand}"/>
                <Button Content="+ 添加互锁" Width="90" Margin="5,0"
                        Command="{Binding AddRuleCommand}"/>
                <Button Content="🔍 碰撞检测" Width="100" Margin="5,0"
                        Command="{Binding CheckCollisionCommand}"/>
                <Button Content="清空日志" Width="80" Margin="15,0,5,0"
                        Command="{Binding ClearLogCommand}"/>
            </StackPanel>
        </Border>

        <!-- 主内容区 -->
        <Grid Grid.Row="2" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="0.8*"/>
            </Grid.ColumnDefinitions>

            <!-- 安全体积列表 -->
            <Border Grid.Column="0" BorderBrush="#FFCCCCCC" BorderThickness="1" Margin="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="安全体积（碰撞检测对象）" FontWeight="Bold" Margin="5,3" 
                               Background="#FFE3F2FD" Padding="5,2"/>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Volumes}" AutoGenerateColumns="False" 
                              IsReadOnly="True" Margin="2" CanUserAddRows="False"
                              SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="100"/>
                            <DataGridTextColumn Header="类型" Binding="{Binding Type}" Width="70"/>
                            <DataGridTextColumn Header="尺寸(mm)" Binding="{Binding SizeText}" Width="120"/>
                            <DataGridTextColumn Header="余量" Binding="{Binding MarginText}" Width="50"/>
                            <DataGridCheckBoxColumn Header="激活" Binding="{Binding IsActive}" Width="50"/>
                            <DataGridTextColumn Header="关联轴" Binding="{Binding LinkedAxesText}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- 互锁规则列表 -->
            <Border Grid.Column="1" BorderBrush="#FFCCCCCC" BorderThickness="1" Margin="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="互锁规则" FontWeight="Bold" Margin="5,3" 
                               Background="#FFF3E5F5" Padding="5,2"/>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Rules}" AutoGenerateColumns="False" 
                              IsReadOnly="True" Margin="2" CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="120"/>
                            <DataGridTextColumn Header="动作" Binding="{Binding Action}" Width="80"/>
                            <DataGridTextColumn Header="表达式" Binding="{Binding ConditionExpression}" Width="*"/>
                            <DataGridCheckBoxColumn Header="启用" Binding="{Binding Enabled}" Width="50"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- 状态与软限位 -->
            <Border Grid.Column="2" BorderBrush="#FFCCCCCC" BorderThickness="1" Margin="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 当前安全状态 -->
                    <GroupBox Grid.Row="0" Header="当前状态" Margin="3">
                        <StackPanel Margin="3">
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="监控运行:" Width="70"/>
                                <TextBlock Text="{Binding MonitorRunningText}" 
                                           Foreground="{Binding MonitorRunningBrush}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="碰撞状态:" Width="70"/>
                                <TextBlock Text="{Binding CollisionStatusText}" 
                                           Foreground="{Binding CollisionStatusBrush}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="互锁状态:" Width="70"/>
                                <TextBlock Text="{Binding InterlockStatusText}" 
                                           Foreground="{Binding InterlockStatusBrush}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="体积数量:" Width="70"/>
                                <TextBlock Text="{Binding VolumeCount}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="规则数量:" Width="70"/>
                                <TextBlock Text="{Binding RuleCount}"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <!-- 软限位配置 -->
                    <GroupBox Grid.Row="1" Header="软限位" Margin="3">
                        <StackPanel Margin="3">
                            <StackPanel Orientation="Horizontal" Margin="0,1">
                                <TextBlock Text="X轴:" Width="30"/>
                                <TextBlock Text="{Binding XLimitText}" FontSize="11"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,1">
                                <TextBlock Text="Y轴:" Width="30"/>
                                <TextBlock Text="{Binding YLimitText}" FontSize="11"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,1">
                                <TextBlock Text="Z轴:" Width="30"/>
                                <TextBlock Text="{Binding ZLimitText}" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <!-- 双头间距 -->
                    <GroupBox Grid.Row="2" Header="双头间距" Margin="3">
                        <StackPanel Margin="3">
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="头A位置:" Width="60"/>
                                <TextBlock Text="{Binding HeadAPosText}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="头B位置:" Width="60"/>
                                <TextBlock Text="{Binding HeadBPosText}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="当前间距:" Width="60"/>
                                <TextBlock Text="{Binding HeadSeparationText}" FontWeight="Bold"
                                           Foreground="{Binding HeadSeparationBrush}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="最小间距:" Width="60"/>
                                <TextBlock Text="{Binding MinSeparationText}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="禁止交叉:" Width="60"/>
                                <TextBlock Text="{Binding PreventCrossingText}"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>
                </Grid>
            </Border>
        </Grid>

        <!-- 底部日志区 -->
        <Border Grid.Row="3" BorderBrush="#FFCCCCCC" BorderThickness="1" Margin="5,0,5,5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" Background="#FFF0F0F0" Margin="3">
                    <TextBlock Text="安全事件日志" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding LastEventTimeText}" Margin="10,0,0,0" 
                               Foreground="Gray" FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>
                <Border Grid.Row="1" Background="#FF1E1E1E">
                    <ListBox ItemsSource="{Binding Logs}" 
                             BorderThickness="0" Background="Transparent"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock FontFamily="Consolas" FontSize="11" Margin="0,1">
                                    <TextBlock.Inlines>
                                        <Run Text="{Binding TimeText}" Foreground="#FF888888"/>
                                        <Run Text=" [" Foreground="#FF888888"/><Run Text="{Binding Level}" Foreground="#FF888888"/><Run Text="] " Foreground="#FF888888"/>
                                        <Run Text="{Binding Message}" Foreground="{Binding MessageBrush}"/>
                                    </TextBlock.Inlines>
                                </TextBlock>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
