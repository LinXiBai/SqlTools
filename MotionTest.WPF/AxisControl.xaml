<UserControl x:Class="MotionTest.WPF.AxisControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="180" Margin="0,5">
    <Border Background="#FFF5F5F5" BorderBrush="#FFCCCCCC" BorderThickness="1" CornerRadius="3">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 轴标题 -->
            <TextBlock x:Name="txtAxisTitle" Grid.Row="0" Grid.Column="0" Text="轴 0" 
                       FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>

            <!-- 状态显示 -->
            <StackPanel Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="4" Orientation="Horizontal">
                <Border x:Name="borderServo" Background="Gray" Width="60" Height="25" Margin="2" CornerRadius="3">
                    <TextBlock Text="伺服" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Border x:Name="borderRunning" Background="Gray" Width="60" Height="25" Margin="2" CornerRadius="3">
                    <TextBlock Text="运行" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Border x:Name="borderAlarm" Background="Gray" Width="60" Height="25" Margin="2" CornerRadius="3">
                    <TextBlock Text="报警" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Border x:Name="borderHome" Background="Gray" Width="60" Height="25" Margin="2" CornerRadius="3">
                    <TextBlock Text="原点" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock x:Name="txtPosition" Text="位置: 0.000" Margin="10,0,0,0" 
                           VerticalAlignment="Center" FontSize="14" FontWeight="Bold"/>
            </StackPanel>

            <!-- 伺服控制 -->
            <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,5">
                <Button x:Name="btnServoOn" Content="伺服 ON" Width="70" Height="28" Margin="2" Click="btnServoOn_Click"/>
                <Button x:Name="btnServoOff" Content="伺服 OFF" Width="70" Height="28" Margin="2" Click="btnServoOff_Click"/>
                <Button x:Name="btnHome" Content="回零" Width="60" Height="28" Margin="10,2,2,2" Click="btnHome_Click"/>
                <TextBox x:Name="txtHomeSpeed" Text="1000" Width="60" Height="28" Margin="2" VerticalContentAlignment="Center"/>
                <TextBlock Text="pps" VerticalAlignment="Center" Margin="2,0,0,0"/>
            </StackPanel>

            <!-- 运动控制 -->
            <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="5" Orientation="Horizontal" Margin="0,5">
                <TextBlock Text="位置:" VerticalAlignment="Center" Margin="2"/>
                <TextBox x:Name="txtTargetPos" Text="10000" Width="80" Height="28" Margin="2" VerticalContentAlignment="Center"/>
                <TextBlock Text="速度:" VerticalAlignment="Center" Margin="10,2,2,2"/>
                <TextBox x:Name="txtSpeed" Text="5000" Width="80" Height="28" Margin="2" VerticalContentAlignment="Center"/>
                <TextBlock Text="pps" VerticalAlignment="Center" Margin="2,0,0,0"/>
                <Button x:Name="btnMoveAbs" Content="绝对运动" Width="70" Height="28" Margin="10,2,2,2" Click="btnMoveAbs_Click"/>
                <Button x:Name="btnMoveRel" Content="相对运动" Width="70" Height="28" Margin="2" Click="btnMoveRel_Click"/>
                <TextBox x:Name="txtRelDistance" Text="1000" Width="60" Height="28" Margin="10,2,2,2" VerticalContentAlignment="Center"/>
            </StackPanel>

            <!-- JOG和停止 -->
            <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="5" Orientation="Horizontal" Margin="0,5">
                <Button x:Name="btnJogMinus" Content="JOG-" Width="60" Height="28" Margin="2" 
                        PreviewMouseDown="btnJogMinus_PreviewMouseDown" PreviewMouseUp="btnJogMinus_PreviewMouseUp"/>
                <Button x:Name="btnJogPlus" Content="JOG+" Width="60" Height="28" Margin="2" 
                        PreviewMouseDown="btnJogPlus_PreviewMouseDown" PreviewMouseUp="btnJogPlus_PreviewMouseUp"/>
                <TextBox x:Name="txtJogSpeed" Text="2000" Width="60" Height="28" Margin="10,2,2,2" VerticalContentAlignment="Center"/>
                <TextBlock Text="pps" VerticalAlignment="Center" Margin="2,0,0,0"/>
                <Button x:Name="btnStop" Content="停止" Width="60" Height="28" Margin="20,2,2,2" 
                        Background="#FFFFA726" Foreground="White" Click="btnStop_Click"/>
                <Button x:Name="btnEmgStop" Content="急停" Width="60" Height="28" Margin="2" 
                        Background="#FFE53935" Foreground="White" Click="btnEmgStop_Click"/>
                <Button x:Name="btnSetPos" Content="设位置" Width="60" Height="28" Margin="20,2,2,2" Click="btnSetPos_Click"/>
                <TextBox x:Name="txtSetPos" Text="0" Width="60" Height="28" Margin="2" VerticalContentAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
