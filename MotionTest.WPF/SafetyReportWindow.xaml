<Window x:Class="MotionTest.WPF.SafetyReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:MotionTest.WPF.ViewModels"
        mc:Ignorable="d"
        Title="安全事件统计报表" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Border Grid.Row="0" Background="#FF2D2D30" Padding="15,10">
            <TextBlock Text="{Binding ReportTitle}" 
                       Foreground="White" FontSize="18" FontWeight="Bold"/>
        </Border>

        <!-- 快捷筛选栏 -->
        <Border Grid.Row="1" Background="#FFF5F5F5" BorderBrush="#FFCCCCCC" BorderThickness="0,0,0,1" Padding="10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="时间范围:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <Button Content="今天" Width="60" Margin="3,0" Command="{Binding TodayCommand}"/>
                <Button Content="本周" Width="60" Margin="3,0" Command="{Binding ThisWeekCommand}"/>
                <Button Content="本月" Width="60" Margin="3,0" Command="{Binding ThisMonthCommand}"/>
                <Button Content="近7天" Width="60" Margin="3,0" Command="{Binding Last7DaysCommand}"/>
                <Button Content="近30天" Width="60" Margin="3,0" Command="{Binding Last30DaysCommand}"/>
                <Separator Margin="10,0" Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"/>
                <TextBlock Text="自定义:" VerticalAlignment="Center" Margin="0,0,3,0"/>
                <DatePicker SelectedDate="{Binding StartDate}" VerticalAlignment="Center" Width="120"/>
                <TextBlock Text="~" VerticalAlignment="Center" Margin="3,0"/>
                <DatePicker SelectedDate="{Binding EndDate}" VerticalAlignment="Center" Width="120"/>
                <Button Content="🔄 刷新" Width="70" Margin="10,0,3,0" 
                        Command="{Binding RefreshCommand}" Background="#FF2196F3" Foreground="White"/>
                <Button Content="📤 导出" Width="70" Margin="3,0" 
                        Command="{Binding ExportCommand}" Background="#FF4CAF50" Foreground="White"/>
            </StackPanel>
        </Border>

        <!-- 统计卡片 -->
        <Grid Grid.Row="2" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <ItemsControl Grid.ColumnSpan="5" ItemsSource="{Binding StatCards}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="5"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{Binding BackgroundBrush}" 
                                CornerRadius="4" Margin="5" Padding="15,10">
                            <StackPanel>
                                <TextBlock Text="{Binding Icon}" FontSize="24" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding Count}" FontSize="28" FontWeight="Bold" 
                                           Foreground="{Binding ForegroundBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding Title}" FontSize="12" 
                                           Foreground="{Binding ForegroundBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>

        <!-- 图表 + 表格区域 -->
        <Grid Grid.Row="3" Margin="10,0,10,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="200"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 柱状图标题 -->
            <TextBlock Grid.Row="0" Text="📈 每日安全事件趋势" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>

            <!-- 柱状图 -->
            <Border Grid.Row="1" BorderBrush="#FFCCCCCC" BorderThickness="1" Background="#FFFAFAFA">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding DailyItems}" Margin="10">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Width="40" Margin="2,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <!-- 柱状图堆叠 -->
                                    <StackPanel Grid.Row="0" VerticalAlignment="Bottom" Orientation="Vertical">
                                        <Rectangle Fill="#FF4CAF50" Height="{Binding InfoBarHeight}" Width="36" 
                                                   ToolTip="{Binding InfoCount, StringFormat=Info: {0}}"/>
                                        <Rectangle Fill="#FFFF9800" Height="{Binding WarningBarHeight}" Width="36" 
                                                   ToolTip="{Binding WarningCount, StringFormat=Warning: {0}}"/>
                                        <Rectangle Fill="#FFFF5722" Height="{Binding ErrorBarHeight}" Width="36" 
                                                   ToolTip="{Binding ErrorCount, StringFormat=Error: {0}}"/>
                                        <Rectangle Fill="#FFF44336" Height="{Binding FatalBarHeight}" Width="36" 
                                                   ToolTip="{Binding FatalCount, StringFormat=Fatal: {0}}"/>
                                    </StackPanel>
                                    <!-- 日期标签 -->
                                    <TextBlock Grid.Row="1" Text="{Binding DateLabel}" FontSize="9" 
                                               HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <!-- 图例 -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5">
                <Rectangle Fill="#FFF44336" Width="12" Height="12" Margin="5,0"/>
                <TextBlock Text="Fatal (急停)" FontSize="11" Margin="0,0,15,0"/>
                <Rectangle Fill="#FFFF5722" Width="12" Height="12" Margin="5,0"/>
                <TextBlock Text="Error (碰撞)" FontSize="11" Margin="0,0,15,0"/>
                <Rectangle Fill="#FFFF9800" Width="12" Height="12" Margin="5,0"/>
                <TextBlock Text="Warning (互锁)" FontSize="11" Margin="0,0,15,0"/>
                <Rectangle Fill="#FF4CAF50" Width="12" Height="12" Margin="5,0"/>
                <TextBlock Text="Info (信息)" FontSize="11" Margin="0,0,15,0"/>
            </StackPanel>

            <!-- 数据明细表格 -->
            <Border Grid.Row="3" BorderBrush="#FFCCCCCC" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="📋 每日明细" FontWeight="Bold" Margin="5,3" 
                               Background="#FFE3F2FD" Padding="5,2"/>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding DailyItems}" 
                              AutoGenerateColumns="False" IsReadOnly="True" 
                              CanUserAddRows="False" Margin="2">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="日期" Binding="{Binding Date, StringFormat=yyyy-MM-dd}" Width="100"/>
                            <DataGridTextColumn Header="急停" Binding="{Binding FatalCount}" Width="80">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#FFF44336"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="碰撞" Binding="{Binding ErrorCount}" Width="80">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#FFFF5722"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="互锁" Binding="{Binding WarningCount}" Width="80">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#FFFF9800"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="信息" Binding="{Binding InfoCount}" Width="80">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#FF4CAF50"/>
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="合计" Binding="{Binding TotalCount}" Width="80">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
