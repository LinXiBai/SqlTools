<Window x:Class="MotionTest.WPF.Views.SafetyStatisticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:MotionTest.WPF.ViewModels"
        xmlns:local="clr-namespace:MotionTest.WPF.Views"
        mc:Ignorable="d"
        Title="安全事件统计报表" 
        Height="720" Width="980"
        WindowStartupLocation="CenterScreen"
        Background="#FFF5F5F5"
        FontSize="13">

    <Window.Resources>
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="BorderBrush" Value="#FFE0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect ShadowDepth="1" BlurRadius="4" Opacity="0.15"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SummaryValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="SummaryLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#FF666666"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>

        <Style x:Key="InsightValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="QuickButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Background" Value="#FFE3F2FD"/>
            <Setter Property="Foreground" Value="#FF1565C0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFBBDEFB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Background" Value="#FF2196F3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF1976D2"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#FFBBBBBB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0" Text="安全事件统计报表" FontSize="20" FontWeight="Bold" Margin="0,0,0,8"/>

        <!-- 筛选条件 -->
        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="开始日期:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <DatePicker Grid.Row="0" Grid.Column="1" SelectedDate="{Binding StartDate}" VerticalAlignment="Center"/>

                <TextBlock Grid.Row="0" Grid.Column="2" Text="结束日期:" VerticalAlignment="Center" Margin="12,0,6,0"/>
                <DatePicker Grid.Row="0" Grid.Column="3" SelectedDate="{Binding EndDate}" VerticalAlignment="Center"/>

                <TextBlock Grid.Row="0" Grid.Column="4" Text="统计周期:" VerticalAlignment="Center" Margin="12,0,6,0"/>
                <ComboBox Grid.Row="0" Grid.Column="5" 
                          ItemsSource="{Binding PeriodTypes}"
                          SelectedItem="{Binding PeriodType}"
                          VerticalAlignment="Center">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock>
                                <TextBlock.Text>
                                    <Binding>
                                        <Binding.Converter>
                                            <local:StatPeriodTypeConverter/>
                                        </Binding.Converter>
                                    </Binding>
                                </TextBlock.Text>
                            </TextBlock>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <StackPanel Grid.Row="0" Grid.Column="6" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="刷新" Command="{Binding RefreshCommand}"/>
                    <Button Content="导出 CSV" Command="{Binding ExportCsvCommand}" Background="#FF4CAF50"/>
                    <Button Content="导出 JSON" Command="{Binding ExportJsonCommand}" Background="#FFFF9800"/>
                </StackPanel>

                <!-- 快捷日期选择 -->
                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="7" 
                            Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock Text="快捷选择:" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="#FF888888" FontSize="12"/>
                    <Button Style="{StaticResource QuickButtonStyle}" Content="今天" Command="{Binding TodayCommand}"/>
                    <Button Style="{StaticResource QuickButtonStyle}" Content="最近7天" Command="{Binding Last7DaysCommand}"/>
                    <Button Style="{StaticResource QuickButtonStyle}" Content="本月" Command="{Binding ThisMonthCommand}"/>
                    <Button Style="{StaticResource QuickButtonStyle}" Content="本年" Command="{Binding ThisYearCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 汇总卡片 -->
        <UniformGrid Grid.Row="2" Columns="4" Margin="0,0,0,6">
            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="{Binding TotalEvents}" Style="{StaticResource SummaryValueStyle}" Foreground="#FF2196F3"/>
                    <TextBlock Text="总事件数" Style="{StaticResource SummaryLabelStyle}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="{Binding TotalCollisions}" Style="{StaticResource SummaryValueStyle}" Foreground="Red"/>
                    <TextBlock Text="碰撞次数" Style="{StaticResource SummaryLabelStyle}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="{Binding TotalInterlocks}" Style="{StaticResource SummaryValueStyle}" Foreground="Orange"/>
                    <TextBlock Text="互锁次数" Style="{StaticResource SummaryLabelStyle}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="{Binding TotalEStops}" Style="{StaticResource SummaryValueStyle}" Foreground="DarkRed"/>
                    <TextBlock Text="急停次数" Style="{StaticResource SummaryLabelStyle}"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- 洞察指标栏 -->
        <Border Grid.Row="3" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,6"
                Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}, ConverterParameter=Inverted}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding AvgCollisions}" Style="{StaticResource InsightValueStyle}" Foreground="Red"/>
                    <TextBlock Text="日均碰撞" FontSize="11" Foreground="#FF888888"/>
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding AvgInterlocks}" Style="{StaticResource InsightValueStyle}" Foreground="Orange"/>
                    <TextBlock Text="日均互锁" FontSize="11" Foreground="#FF888888"/>
                </StackPanel>
                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding AvgEStops}" Style="{StaticResource InsightValueStyle}" Foreground="DarkRed"/>
                    <TextBlock Text="日均急停" FontSize="11" Foreground="#FF888888"/>
                </StackPanel>
                <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding PeakCollisionCount}" Style="{StaticResource InsightValueStyle}" Foreground="Red"/>
                    <TextBlock Text="{Binding PeakCollisionPeriod, StringFormat='峰值碰撞 ({0})'}" FontSize="11" Foreground="#FF888888"/>
                </StackPanel>
                <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding PeakInterlockCount}" Style="{StaticResource InsightValueStyle}" Foreground="Orange"/>
                    <TextBlock Text="{Binding PeakInterlockPeriod, StringFormat='峰值互锁 ({0})'}" FontSize="11" Foreground="#FF888888"/>
                </StackPanel>
                <StackPanel Grid.Column="5" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding PeakEStopCount}" Style="{StaticResource InsightValueStyle}" Foreground="DarkRed"/>
                    <TextBlock Text="{Binding PeakEStopPeriod, StringFormat='峰值急停 ({0})'}" FontSize="11" Foreground="#FF888888"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 数据区域 -->
        <Grid Grid.Row="4" Margin="0,0,0,6">
            <!-- 数据表格 -->
            <Border Style="{StaticResource CardBorderStyle}" 
                    Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}, ConverterParameter=Inverted}">
                <DataGrid ItemsSource="{Binding Stats}" 
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          GridLinesVisibility="Horizontal"
                          BorderThickness="0"
                          HeadersVisibility="Column"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserReorderColumns="False"
                          CanUserResizeRows="False"
                          AlternatingRowBackground="#FFF8F8F8"
                          RowHeaderWidth="0"
                          MouseDoubleClick="DataGrid_MouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="周期" Binding="{Binding Period}" Width="140" FontWeight="SemiBold"/>
                        <DataGridTextColumn Header="碰撞" Binding="{Binding CollisionCount}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{Binding CollisionBrush}"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="互锁" Binding="{Binding InterlockCount}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{Binding InterlockBrush}"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="急停" Binding="{Binding EStopCount}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{Binding EStopBrush}"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="信息" Binding="{Binding InfoCount}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#FF666666"/>
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="合计" Binding="{Binding TotalCount}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- 空数据提示 -->
            <Border Style="{StaticResource CardBorderStyle}" 
                    Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="40">
                    <TextBlock Text="📊" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock Text="暂无数据" FontSize="18" FontWeight="SemiBold" 
                               Foreground="#FF888888" HorizontalAlignment="Center"/>
                    <TextBlock Text="请调整日期范围或统计周期后重试" FontSize="13" 
                               Foreground="#FFAAAAAA" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <!-- Loading 遮罩 -->
            <Border Background="#88FFFFFF" 
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"
                    CornerRadius="6">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="120" Height="4" 
                                 Background="#FFE0E0E0" Foreground="#FF2196F3" BorderThickness="0"/>
                    <TextBlock Text="正在统计..." FontSize="13" Foreground="#FF666666" 
                               HorizontalAlignment="Center" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 状态栏 -->
        <TextBlock Grid.Row="5" 
                   Text="{Binding RowCount, StringFormat='共 {0} 条记录'}"
                   Foreground="#FF888888" 
                   FontSize="12"
                   HorizontalAlignment="Right"/>
    </Grid>
</Window>
