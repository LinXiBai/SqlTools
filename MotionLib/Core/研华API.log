    {
        uint result = 0u;
        if (MapInfoArray == null || MapInfoArray.Length < 1)
        {
            return result;
        }

        int cb = Marshal.SizeOf(typeof(DEV_IO_MAP_INFO)) * MapInfoArray.Length;
        IntPtr intPtr = Marshal.AllocHGlobal(cb);
        try
        {
            for (uint num = 0u; num < MapInfoArray.Length; num++)
            {
                Marshal.StructureToPtr(ptr: new IntPtr(intPtr.ToInt64() + Marshal.SizeOf(typeof(DEV_IO_MAP_INFO)) * num), structure: (object)MapInfoArray[num], fDeleteOld: true);
            }

            return Acm_DevDownLoadMapInfo(DeviceHandle, MapType, intPtr, ArrayLength);
        }
        finally
        {
            Marshal.FreeHGlobal(intPtr);
        }
    }

