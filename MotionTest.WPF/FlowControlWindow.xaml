<Window x:Class="MotionTest.WPF.FlowControlWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MotionTest.WPF"
        xmlns:ctrl="clr-namespace:MotionTest.WPF.Controls"
        mc:Ignorable="d"
        Title="流程控制与轨迹显示" Height="900" Width="1400"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- 左侧面板：流程控制 -->
        <Grid Grid.Column="0" Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="200"/>
            </Grid.RowDefinitions>
            
            <!-- 状态机控制 -->
            <GroupBox Grid.Row="0" Header="状态机控制" Margin="0,0,0,5">
                <StackPanel Margin="5">
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <TextBlock Text="状态:" Width="50" VerticalAlignment="Center"/>
                        <Border x:Name="borderStatus" Width="80" Height="24" Background="Gray" 
                                CornerRadius="3" HorizontalAlignment="Left">
                            <TextBlock x:Name="txtMachineStatus" Text="空闲" Foreground="White" 
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <TextBlock Text="时间:" Width="50" VerticalAlignment="Center"/>
                        <TextBlock x:Name="txtExecutionTime" Text="0 ms" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <Button x:Name="btnStart" Content="启动" Width="60" Margin="2" Click="btnStart_Click"/>
                        <Button x:Name="btnStop" Content="停止" Width="60" Margin="2" Click="btnStop_Click"/>
                        <Button x:Name="btnPause" Content="暂停" Width="60" Margin="2" Click="btnPause_Click"/>
                        <Button x:Name="btnReset" Content="重置" Width="60" Margin="2" Click="btnReset_Click"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>
            
            <!-- 流程配置 -->
            <GroupBox Grid.Row="1" Header="流程配置" Margin="0,0,0,5">
                <StackPanel Margin="5">
                    <ComboBox x:Name="cmbFlowType" SelectedIndex="0" Margin="0,2">
                        <ComboBoxItem Content="单轴PTP运动"/>
                        <ComboBoxItem Content="双轴直线插补"/>
                        <ComboBoxItem Content="双轴圆弧插补"/>
                        <ComboBoxItem Content="多轴并行运动"/>
                        <ComboBoxItem Content="IO信号测试"/>
                        <ComboBoxItem Content="综合流程"/>
                    </ComboBox>
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="速度%:" Width="45" VerticalAlignment="Center"/>
                        <Slider x:Name="sliderSpeed" Minimum="10" Maximum="100" Value="50" Width="150" 
                                TickFrequency="10" TickPlacement="BottomRight"/>
                        <TextBlock x:Name="txtSpeedValue" Text="50%" Width="40" Margin="5,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <TextBlock Text="超时:" Width="45" VerticalAlignment="Center"/>
                        <TextBox x:Name="txtTimeout" Text="30000" Width="60" VerticalAlignment="Center"/>
                        <TextBlock Text="ms" VerticalAlignment="Center" Margin="2,0"/>
                    </StackPanel>
                    <Button x:Name="btnCreateFlow" Content="创建流程" Margin="0,5" Click="btnCreateFlow_Click"/>
                </StackPanel>
            </GroupBox>
            
            <!-- 模块树 -->
            <GroupBox Grid.Row="2" Header="流程模块" Margin="0,0,0,5">
                <TreeView x:Name="treeModules" Margin="2">
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate DataType="{x:Type local:ModuleTreeItem}">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="10" Height="10" Fill="{Binding StatusColor}" Margin="0,0,5,0"/>
                                <TextBlock Text="{Binding Name}" FontWeight="{Binding FontWeight}"/>
                                <TextBlock Text="{Binding StatusText}" Foreground="Gray" Margin="5,0,0,0"/>
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </GroupBox>
            
            <!-- 模块详情 -->
            <GroupBox Grid.Row="3" Header="选中模块详情" Height="150" Margin="0,0,0,5">
                <ScrollViewer>
                    <TextBlock x:Name="txtModuleDetails" Text="" TextWrapping="Wrap" FontSize="11"/>
                </ScrollViewer>
            </GroupBox>
            
            <!-- 执行日志 -->
            <GroupBox Grid.Row="4" Header="执行日志">
                <TextBox x:Name="txtLog" IsReadOnly="True" VerticalScrollBarVisibility="Auto" 
                         FontFamily="Consolas" FontSize="10" TextWrapping="Wrap"/>
            </GroupBox>
        </Grid>
        
        <!-- 分隔条 -->
        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#DDDDDD"/>
        
        <!-- 右侧：图表显示 -->
        <Grid Grid.Column="2" Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="250"/>
            </Grid.RowDefinitions>
            
            <!-- 主图表 -->
            <ctrl:TrajectoryChart x:Name="trajectoryChart" Grid.Row="0"/>
            
            <!-- 分隔条 -->
            <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" Background="#DDDDDD"/>
            
            <!-- 统计信息和历史记录 -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="350"/>
                </Grid.ColumnDefinitions>
                
                <!-- 当前轨迹统计 -->
                <GroupBox Grid.Column="0" Header="轨迹统计">
                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="总时长:" FontWeight="Bold"/>
                            <TextBlock x:Name="statDuration" Text="-"/>
                            <TextBlock Text="采样点数:" FontWeight="Bold" Margin="0,5,0,0"/>
                            <TextBlock x:Name="statPointCount" Text="-"/>
                            <TextBlock Text="轴数量:" FontWeight="Bold" Margin="0,5,0,0"/>
                            <TextBlock x:Name="statAxisCount" Text="-"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="最大速度:" FontWeight="Bold"/>
                            <TextBlock x:Name="statMaxVel" Text="-"/>
                            <TextBlock Text="行程距离:" FontWeight="Bold" Margin="0,5,0,0"/>
                            <TextBlock x:Name="statDistance" Text="-"/>
                            <TextBlock Text="到位精度:" FontWeight="Bold" Margin="0,5,0,0"/>
                            <TextBlock x:Name="statAccuracy" Text="-"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>
                
                <!-- 历史记录 -->
                <GroupBox Grid.Column="2" Header="历史记录">
                    <ListView x:Name="lvHistory" SelectionChanged="lvHistory_SelectionChanged">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="时间" Width="80" DisplayMemberBinding="{Binding StartTime, StringFormat=HH:mm:ss}"/>
                                <GridViewColumn Header="流程" Width="80" DisplayMemberBinding="{Binding FlowName}"/>
                                <GridViewColumn Header="结果" Width="50">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding IsSuccess}" 
                                                       Foreground="{Binding IsSuccess, Converter={StaticResource BoolToBrushConverter}}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="耗时" Width="60" DisplayMemberBinding="{Binding TotalDuration, StringFormat=hh\\:mm\\:ss\\.fff}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </GroupBox>
            </Grid>
        </Grid>
    </Grid>
    
    <Window.Resources>
        <local:BoolToBrushConverter x:Key="BoolToBrushConverter"/>
    </Window.Resources>
</Window>
