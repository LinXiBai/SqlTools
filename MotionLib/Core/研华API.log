    public static uint mAcm_DevGetRunningAresName(IntPtr DeviceHandle, uint Id, ref string FileName)
    {
        FileName = "";
        StringBuilder stringBuilder = new StringBuilder(32);
        uint num = mAcm_DevGetRunningAresName_(DeviceHandle, Id, stringBuilder);
        if (num != 0)
        {
            return num;
        }

        FileName = stringBuilder.ToString();
        return num;
    }

